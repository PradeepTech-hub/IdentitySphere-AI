# Gmail SMTP — one-time app setup (run: python setup_gmail.py)
# GMAIL_USER = the Gmail account this app uses to SEND emails.
# OTP is always delivered TO whatever email address the user enters on the login form.
# Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your sixteen char app password

# Auth signing key (change in production)
AUTH_SECRET_KEY=change-this-to-a-long-random-string

# WebAuthn — must match how you open the app in the browser
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173
# Optional extra origins (comma-separated), e.g. http://127.0.0.1:5173
WEBAUTHN_ORIGINS=
